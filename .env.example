# ============================================================
# music-app 環境変数テンプレート
# 値は各環境で上書きしてください。秘密情報はここに書かない。
# ============================================================

# Supabase プロジェクトURL（公開値）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase 匿名キー（公開値・RLSで保護される前提）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role キー（管理者権限・絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL 接続URL（Prisma用）
# パスワードは URLエンコード必須（@ → %40 等）
DATABASE_URL=postgresql://postgres.REF:ENCODED_PASSWORD@HOST:5432/postgres
DIRECT_URL=postgresql://postgres.REF:ENCODED_PASSWORD@HOST:5432/postgres

# ------------------------------------------------------------
# Python 解析実行制御（Phase 0-5）
# ------------------------------------------------------------
# true のときのみ Python 解析を実行。未設定/false/他の値 → 明示スキップ
# Vercel本番では false に設定し、Python非対応環境での失敗を回避
ENABLE_PYTHON_ANALYSIS=false

# ENABLE_PYTHON_ANALYSIS=true のとき必須。Python venv の絶対パス
# 例: C:/Users/.../venv/Scripts/python.exe
# フォールバックなし。未設定で ENABLE=true のときは実行時に throw される
PYTHON_PATH=
