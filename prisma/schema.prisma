generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  processing
  done
  error
  queued
  retrying
}

model User {
  id             String        @id @default(cuid())
  supabaseUserId String        @unique
  name           String
  role           Role          @default(student)
  plan           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  performances   Performance[]
  scores         Score[]

  // ▼ 練習メニュー追加分
  practiceItems        PracticeItem[]
  practicePerformances PracticePerformance[]
  weaknesses           UserWeakness[]

  // ▼ S-1: アカウント設定追加分
  aiTrainingOptIn          Boolean          @default(false)
  aiTrainingOptInChangedAt DateTime?
  deletedAt                DateTime? // 退会受付時刻 (idempotency key 兼用)
  feedbacks                Feedback[]
  supportInquiries         SupportInquiry[]

  // ▼ v3.2.2 上達ループエンジン (Commit 1)
  userSkillScores           UserSkillScore[]
  userSkillSubScores        UserSkillSubScore[]
  userSkillTaskCards        UserSkillTaskCard[]
  userGrade                 UserGrade?
  performanceSkillFeedbacks PerformanceSkillFeedback[]

  // ▼ v1.3 上達ループエンジン拡張 (R3 = C ハイブリッド構造)
  songMasteries          SongMastery[]
  userGradeProgress      UserGradeProgress?
  skillTaskCards         SkillTaskCard[]
  userPracticeMasteries  UserPracticeMastery[]
  userTechniqueMasteries UserTechniqueMastery[]

  @@index([role])
}

model Score {
  id               String    @id @default(cuid())
  createdById      String
  title            String
  composer         String?
  originalXmlPath  String
  generatedXmlPath String?
  analysisStatus   JobStatus @default(processing)
  buildStatus      JobStatus @default(processing)
  retryCount       Int       @default(0)
  errorMessage     String?
  lastAttemptedAt  DateTime?
  executionId      String?
  idempotencyKey   String?   @unique
  keyTonic         String?
  keyMode          String?
  timeNumerator    Int?
  timeDenominator  Int?
  defaultTempo     Int?
  isShared         Boolean   @default(false) // true=全ユーザー閲覧可のサンプル

  // ループエンジン用フィールド (2026-05-10 追加 / v1.3 で difficulty → star リネーム)
  // 「次のチャレンジ」レコメンドで Score も対象とするため、
  // PracticeItem と同形のメタデータを Score にも持たせる。
  star             Int? // 1〜10、グレード範囲フィルタ用 (旧名 difficulty)
  skillSubTaskTags Json? // sub_task ID 配列、レコメンド対象判定用

  // ▼ v1.3 上達ループエンジン拡張 (R4 = D 確定)
  // ownerScope = "admin" の Score のみがループエンジンの対象。
  // R4 = D により既存 Score 全件 "admin" にマイグレーション。
  // 将来ユーザーアップロード機能を有効化するときは "user" を発行する。
  ownerScope String @default("admin")

  createdAt    DateTime      @default(now())
  deletedAt    DateTime? // 論理削除フラグ (NULL=有効、値あり=削除済み)
  performances Performance[]

  // ▼ v1.3 上達ループエンジン (back-references)
  songMasteries            SongMastery[]
  skillTaskCards           SkillTaskCard[]
  missingPracticeItemFlags MissingPracticeItemFlag[]
  scoreTechniqueTags       ScoreTechniqueTag[] // Phase 3c (Q4=B): 完全習得判定の技法集合

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([isShared])
  @@index([ownerScope])
}

model Performance {
  id                   String            @id @default(cuid())
  performanceType      PerformanceType
  performanceStatus    PerformanceStatus @default(uploaded)
  userId               String
  scoreId              String
  name                 String? // 表示名 (例: "Performance #3")。null = 旧データ
  audioPath            String
  audioFeaturesPath    String?
  comparisonResultPath String?
  pseudoXmlPath        String?
  performanceDuration  Float?
  performanceDate      DateTime?
  uploadedAt           DateTime          @default(now())
  createdAt            DateTime          @default(now())
  score                Score             @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ▼ 解析結果サマリー（段階3: ハイブリッド方式）
  pitchAccuracy   Float? // 0-100 ピッチ正確率（頻繁表示 → カラム）
  timingAccuracy  Float? // 0-100 タイミング正確率（頻繁表示 → カラム）
  overallScore    Float? // 0-100 総合スコア（v1.0 旧式: pitch×0.6 + timing×0.4 / v1.3 で計算式変更予定: (pitch + rhythm + bowing) / 3）
  evaluatedNotes  Int? // 評価対象ノート数
  analysisSummary Json? // 将来の拡張用（ビブラート・弓使い・音色等）

  // ▼ v1.3 上達ループエンジン拡張 (R1 = B: pitch/rhythm/bowing 体系)
  // 旧 timingAccuracy は Phase 2 で rhythmAccuracy にリネーム予定 (案 Y)。
  // 移行期間中は両カラムを併存 (timingAccuracy は legacy、rhythmAccuracy が正)。
  rhythmAccuracy Float? // 0-100 リズム正確率
  bowingAccuracy Float? // 0-100 ボウイング正確率 (弦移動・スラー・強弱変化)

  // ▼ v1.3 上達ループエンジン: PracticePerformance ミラー
  // (score_full のループエンジン処理を Score 演奏でも実行可能にする)
  pitchSkillScore      Float?
  rhythmSkillScore     Float?
  bowingSkillScore     Float?
  skillSubScores       Json? // 9 sub task の結果 (各 score, target_count, matched 等)
  problematicPositions Json? // 「気になる箇所」配列

  // ▼ 非同期ジョブライフサイクル（Cloud Run Jobs）
  analysisStatus  JobStatus @default(done)
  retryCount      Int       @default(0)
  errorMessage    String?
  lastAttemptedAt DateTime?
  executionId     String?
  idempotencyKey  String?   @unique

  // ▼ v1.3 上達ループエンジン (back-references)
  skillFeedbacks PerformanceSkillFeedback[]

  @@index([scoreId])
  @@index([userId, uploadedAt])
}

enum Role {
  student
  teacher
  admin
}

enum PerformanceType {
  user
  pro
}

enum PerformanceStatus {
  uploaded
  invalid
  deleted
}

// =============================================
// ▼ 練習メニュー機能
// =============================================

enum PracticeCategory {
  scale
  arpeggio
  etude
  // 2026-05-31 練習メニュー再編: 基礎練の新カテゴリ追加
  fingering
  bowing
  position_shift
  double_stop
}

model PracticeItem {
  id               String           @id @default(cuid())
  category         PracticeCategory
  title            String
  composer         String?
  description      String?
  descriptionShort String?

  keyTonic   String
  keyMode    String
  tempoMin   Int?
  tempoMax   Int?
  positions  String[]
  instrument String   @default("violin")

  originalXmlPath  String
  generatedXmlPath String?
  analysisPath     String?
  analysisStatus   JobStatus @default(processing)
  buildStatus      JobStatus @default(processing)
  retryCount       Int       @default(0)
  errorMessage     String?
  lastAttemptedAt  DateTime?
  executionId      String?
  idempotencyKey   String?   @unique

  ownerUserId String? // null=運営サンプル（全員閲覧可）, 値あり=そのユーザーのみ
  owner       User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  source      String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  metadata    Json? // ▼ 追加
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ▼ v3.2.2 上達ループエンジン (Commit 1、致命1: star は Commit 1.5 で backfill / v1.3 で difficulty → star)
  star             Int? // 1〜10、Commit 1.5 で backfill 後は NOT NULL 化検討 (旧名 difficulty)
  skillSubTaskTags Json? // 9 sub task のタグ配列 (例: ["pitch_overall", "string_change_volume"])
  // C7: PracticeItemTechnique とは独立した別系統 (Commit 8 で初期付与)

  techniques           PracticeItemTechnique[]
  practicePerformances PracticePerformance[]

  // ▼ v1.3 上達ループエンジン (back-references)
  subTaskAssignments      SubTaskAssignment[]
  userPracticeMasteries   UserPracticeMastery[]
  practiceItemSubTaskTags PracticeItemSubTaskTag[]

  @@index([category, keyTonic, keyMode])
  @@index([category, isPublished, sortOrder])
  @@index([ownerUserId])
  @@index([category, star]) // v3.2.2: 教材レコメンド用 (Commit 4) / v1.3: difficulty → star rename
}

model TechniqueTag {
  id              String   @id @default(cuid())
  category        String
  name            String
  nameEn          String?
  description     String?
  xmlTags         String[]
  isAnalyzable    String
  implementStatus String

  practiceItems PracticeItemTechnique[]
  weaknesses    UserWeakness[]

  // ▼ v1.3 上達ループエンジン (back-references)
  userTechniqueMasteries   UserTechniqueMastery[]
  missingPracticeItemFlags MissingPracticeItemFlag[]
  scoreTechniqueTags       ScoreTechniqueTag[] // Phase 3c (Q4=B)

  @@unique([category, name])
  @@index([category])
}

model PracticeItemTechnique {
  practiceItemId String
  techniqueTagId String
  isPrimary      Boolean @default(false)

  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id])
  techniqueTag TechniqueTag @relation(fields: [techniqueTagId], references: [id])

  @@id([practiceItemId, techniqueTagId])
}

model PracticePerformance {
  id                   String   @id @default(cuid())
  userId               String
  practiceItemId       String
  name                 String? // 表示名 (例: "Performance #3")。null = 旧データ
  audioPath            String
  comparisonResultPath String?
  performanceDuration  Float?
  uploadedAt           DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id], onDelete: Cascade)

  // ▼ 解析結果サマリー（段階3: ハイブリッド方式）
  pitchAccuracy   Float?
  timingAccuracy  Float?
  overallScore    Float?
  evaluatedNotes  Int?
  analysisSummary Json?

  // ▼ v1.3 上達ループエンジン拡張 (R1 = B: pitch/rhythm/bowing 体系)
  // timingAccuracy は Phase 2 で rhythmAccuracy にリネーム予定 (案 Y)。
  rhythmAccuracy Float?
  bowingAccuracy Float?

  // ▼ 非同期ジョブライフサイクル（Cloud Run Jobs）
  analysisStatus  JobStatus @default(done)
  retryCount      Int       @default(0)
  errorMessage    String?
  lastAttemptedAt DateTime?
  executionId     String?
  idempotencyKey  String?   @unique

  // ▼ v3.2.2 上達ループエンジン (Commit 1、score_full の出力を保存)
  pitchSkillScore      Float?
  rhythmSkillScore     Float?
  bowingSkillScore     Float? // Q5: 弦移動なし曲では null
  skillSubScores       Json? // 9 sub task の結果 (各 score, target_count, matched 等)
  problematicPositions Json? // 「気になる箇所」配列 (発見 A: score_full では未生成、別 commit で対応)

  // ▼ v3.2.2 back-reference
  skillFeedbacks PerformanceSkillFeedback[]

  @@index([userId, practiceItemId, uploadedAt])
  @@index([practiceItemId])
}

model UserWeakness {
  id             String   @id @default(cuid())
  userId         String
  weaknessType   String
  weaknessKey    String
  techniqueTagId String?
  severity       Float
  sampleCount    Int
  lastUpdated    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  techniqueTag TechniqueTag? @relation(fields: [techniqueTagId], references: [id])

  @@unique([userId, weaknessType, weaknessKey])
  @@index([userId, severity])
}

// =============================================
// ▼ S-1: フィードバック・お問い合わせ
// =============================================

model Feedback {
  id           String    @id @default(cuid())
  userId       String? // 退会時 SetNull で匿名化保持
  rating       Int // 1-5
  category     String
  message      String    @db.Text
  contactEmail String?
  createdAt    DateTime  @default(now())
  emailSentAt  DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
}

model SupportInquiry {
  id          String    @id @default(cuid())
  userId      String? // 退会時 SetNull で匿名化保持
  category    String
  subject     String
  message     String    @db.Text
  replyTo     String
  status      String    @default("open") // open | replied | closed
  createdAt   DateTime  @default(now())
  emailSentAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([status])
}

// =============================================
// v3.2.2 上達ループエンジン (Commit 1)
// 設計書 v3.2.2 §4 に基づく
// JobStatus enum は既存温存 (m1 確定)
// =============================================

enum CardType {
  task // 中項目カード (pitch / rhythm / bowing)
  sub_task // 小項目カード (pitch_overall 等)
}

enum CardStatus {
  active // 「気になる箇所」(直近で課題として検出)
  improving // 「改善傾向」(直近3回中 matched=true 1回以下)
  cleared // 「達成」(ユーザーが手動でクリア、C5 確定)
}

enum GradeLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  MASTER
}

// v1.3 B-2: 中項目 (pitch/rhythm/bowing) を enum 化 (大文字スネーク、Postgres 正書)
// 既存 GradeLevel が UPPER_SNAKE スタイルのため統一
enum TaskCategory {
  PITCH
  RHYTHM
  BOWING
}

// v1.3 B-2: アサイン教材カテゴリ (scale/arpeggio/etude) を enum 化
// 既存 PracticeCategory (lower_snake) があるが、v1.3 新規モデル用は UPPER_SNAKE で統一
enum AssignedCategory {
  SCALE
  ARPEGGIO
  ETUDE
  // 2026-05-31 練習メニュー再編: 基礎練の新カテゴリ追加
  FINGERING
  BOWING
  POSITION_SHIFT
  DOUBLE_STOP
}

// 中項目スコア累積 (pitch / rhythm / bowing 各 1 行 / user)
// C2: sampleCount に統一 (totalCount ではない)
model UserSkillScore {
  id            String   @id @default(cuid())
  userId        String
  skillTaskId   String // "pitch" | "rhythm" | "bowing"
  currentScore  Float    @default(0) // 0〜100、指数移動平均で更新
  sampleCount   Int      @default(0) // 累積サンプル数
  lastUpdatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillTaskId])
  @@index([userId, skillTaskId])
}

// 小項目スコア累積 (9 sub task 各 1 行 / user)
// C1: matchedCount/totalCount/matchRate/averageScore/lastMatchedAt 5 列
model UserSkillSubScore {
  id             String    @id @default(cuid())
  userId         String
  skillSubTaskId String // 9 sub task の ID (例: "pitch_overall", "string_change_volume")
  matchedCount   Int       @default(0) // matched=true だった回数
  totalCount     Int       @default(0) // この sub task が判定対象になった回数 (Q5: target_count > 0 のみ)
  matchRate      Float     @default(0) // matchedCount / totalCount (課題ランキング・レコメンド用)
  averageScore   Float? // 該当時のスコア平均
  lastMatchedAt  DateTime?
  lastUpdatedAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillSubTaskId])
  @@index([userId, matchRate]) // 課題ランキング用
}

// カード方式の課題管理
// C3: skillTaskId / skillSubTaskId 別カラム + improvedAt
// C5: 自動 cleared なし、ユーザー手動操作のみ
model UserSkillTaskCard {
  id             String     @id @default(cuid())
  userId         String
  cardType       CardType
  skillTaskId    String? // cardType="task" のとき設定 ("pitch" | "rhythm" | "bowing")
  skillSubTaskId String? // cardType="sub_task" のとき設定 ("pitch_overall" 等)
  status         CardStatus
  createdAt      DateTime   @default(now())
  improvedAt     DateTime? // improving に遷移した日時
  clearedAt      DateTime? // cleared に遷移した日時 (C5: ユーザー手動クリア時のみ)
  lastMatchedAt  DateTime? // 直近 matched=true 日時 (中13: マイページ表示用)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cardType, skillTaskId, skillSubTaskId])
  @@index([userId, status])
}

// グレード制度 (4 段階、永久保持)
// m4: progressData は JSON キャッシュ、オンデマンド更新
model UserGrade {
  id            String     @id @default(cuid())
  userId        String     @unique
  currentGrade  GradeLevel @default(BEGINNER)
  achievedAt    DateTime? // currentGrade に到達した日時
  progressData  Json       @default("{}") // 難易度別の達成済み PracticeItem ID 集合
  lastUpdatedAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 演奏完了画面のフィードバック保存
// C4: ユーザー操作の保存 (生成テキストキャッシュではない、A 案採用)
// MVP では記録のみ、β で自動学習ループの種にする
//
// v1.3 (2026-05-10): PracticePerformance / Performance (Score 演奏) 両方に対応するため
// polymorphic 化。実装制約: practicePerformanceId と performanceId のうち
// 正確に 1 つだけが非 NULL (Postgres CHECK 制約を migration で raw SQL 追加)。
model PerformanceSkillFeedback {
  id                    String   @id @default(cuid())
  practicePerformanceId String? // PracticePerformance 由来の feedback (排他)
  performanceId         String? // v1.3 新規: Score 演奏 (Performance) 由来の feedback (排他)
  userId                String
  positionId            String // problematicPositions の position_id
  selectedSubTaskId     String? // user_selected の場合に設定 (どの sub task が原因か)
  feedbackType          String // "user_selected" | "user_rejected" | "user_uncertain"
  comment               String? // MVP では使わない、β で自由記述用
  createdAt             DateTime @default(now())

  practicePerformance PracticePerformance? @relation(fields: [practicePerformanceId], references: [id], onDelete: Cascade)
  performance         Performance?         @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([practicePerformanceId])
  @@index([performanceId])
  @@index([userId, feedbackType])
}

// =============================================
// v1.3 上達ループエンジン拡張 (2026-05-10)
// 設計書 v1.3 §6-2 に基づく 9 新規テーブル
// R3 = C ハイブリッド: 既存 UserSkillTaskCard / UserSkillScore / UserSkillSubScore は併存
// (Phase 4-5 で整理)
// =============================================

// ─── (1) SongMastery: 曲ごとのユーザー演奏マスター状態 ───
// v1.3 §2-2 §2-6 / §6-2 (1)
// 演奏マスター: 直近 5 回平均 overallScore ≥ 90 かつ累計 ≥ 5
// 完全習得: 演奏マスター + 全演奏技法習得 + 全中課題クリア
model SongMastery {
  id                    String    @id @default(cuid())
  userId                String
  scoreId               String
  recentAverageScore    Float? // 直近 5 回 overallScore 平均
  totalPerformanceCount Int       @default(0)
  isPerformanceMastered Boolean   @default(false)
  isFullyMastered       Boolean   @default(false)
  performanceMasteredAt DateTime?
  fullyMasteredAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  score Score @relation(fields: [scoreId], references: [id], onDelete: Cascade)

  @@unique([userId, scoreId])
  @@index([userId, isFullyMastered])
  @@index([scoreId])
}

// ─── (2) UserGradeProgress: ユーザーの現在★+グレード進捗 ───
// v1.3 §1-2 / §6-2 (2)
// 既存 UserGrade とは別概念で併存 (R3 = C):
//   - UserGrade: 旧設計 (currentGrade, progressData JSON)
//   - UserGradeProgress: v1.3 新設計 (currentStar 1-10 + masteredSongCountAtCurrentStar)
model UserGradeProgress {
  id                             String     @id @default(cuid())
  userId                         String     @unique
  currentStar                    Int        @default(1) // 1-10
  currentGrade                   GradeLevel @default(BEGINNER) // B-1: 既存 GradeLevel enum を再利用
  masteredSongCountAtCurrentStar Int        @default(0) // 同★で何曲習得したか (10 で次の★に昇格)
  masterReachedAt                DateTime? // ★10 (master) 到達日時
  updatedAt                      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentStar])
}

// ─── (3) SkillTaskCard: 曲×中項目の課題カード (v1.3 R3 = C) ───
// v1.3 §3-3 / §6-2 (3)
// 既存 UserSkillTaskCard とは別物:
//   - 既存: (userId, sub_task) で 9 カード
//   - v1.3: (userId, scoreId, taskCategory) で曲ごとに最大 3 カード
// taskCategory ∈ { pitch, rhythm, bowing } (R1 = B)
model SkillTaskCard {
  id            String       @id @default(cuid())
  userId        String
  scoreId       String
  taskCategory  TaskCategory // B-2: enum 化 (PITCH | RHYTHM | BOWING)
  status        String       @default("active") // "active" | "improving" | "cleared"
  generatedAt   DateTime     @default(now())
  lastMatchedAt DateTime?
  clearedAt     DateTime?
  updatedAt     DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  score    Score     @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  subTasks SubTask[]

  @@unique([userId, scoreId, taskCategory])
  @@index([userId, status])
  @@index([scoreId])
}

// ─── (4) SubTask: 中課題カードに紐づく 9 種類の小課題 ───
// v1.3 §6-2 (4)
// subTaskType: 既存 SUB_TASK_IDS の 9 値 (S1 = A 暫定):
//   pitch_overall, pitch_high, pitch_chromatic
//   rhythm_overall, rhythm_fast, rhythm_after_rest
//   string_change_volume, string_change_slur, string_change_timing
model SubTask {
  id              String    @id @default(cuid())
  skillTaskCardId String
  subTaskType     String
  status          String    @default("active") // "active" | "cleared"
  generatedAt     DateTime  @default(now())
  clearedAt       DateTime?
  updatedAt       DateTime  @updatedAt

  skillTaskCard      SkillTaskCard       @relation(fields: [skillTaskCardId], references: [id], onDelete: Cascade)
  subTaskAssignments SubTaskAssignment[]

  @@unique([skillTaskCardId, subTaskType])
  @@index([subTaskType])
}

// ─── (5) SubTaskAssignment: 小課題に自動アサインされた教材 (3 カテゴリ × 1) ───
// v1.3 §2-4 §3-4 / §6-2 (5)
// M6 = B: 1 SubTask に対し scale + arpeggio + etude の 3 件作成
model SubTaskAssignment {
  id               String           @id @default(cuid())
  subTaskId        String
  practiceItemId   String
  assignedCategory AssignedCategory // B-2: enum 化 (SCALE | ARPEGGIO | ETUDE)
  isMastered       Boolean          @default(false)
  masteredAt       DateTime?
  assignedAt       DateTime         @default(now())

  subTask      SubTask      @relation(fields: [subTaskId], references: [id], onDelete: Cascade)
  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id], onDelete: Cascade)

  @@unique([subTaskId, practiceItemId])
  @@index([subTaskId])
  @@index([practiceItemId])
}

// ─── (6) UserPracticeMastery: PracticeItem ごとのユーザー演奏マスター状態 ───
// v1.3 §2-2 / §6-2 (6)
// Phase 3c 追加仕様 (2026-05-16, Tetsuo 確定): 演奏マスター必要回数を 5 回統一に変更
// 演奏マスター: 直近 5 回平均 overallScore ≥ 90 かつ累計 ≥ 5
// (Q1=B 永続: 一度 mastered になったら以降の再計算で false に戻さない、masteredAt 固定)
model UserPracticeMastery {
  id                    String    @id @default(cuid())
  userId                String
  practiceItemId        String
  recentAverageScore    Float?
  totalPerformanceCount Int       @default(0)
  isPerformanceMastered Boolean   @default(false)
  masteredAt            DateTime?
  updatedAt             DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id], onDelete: Cascade)

  @@unique([userId, practiceItemId])
  @@index([userId, isPerformanceMastered])
}

// ─── (7) UserTechniqueMastery: 演奏技法ごとのユーザー習得状態 ───
// v1.3 §2-3 / §6-2 (7)
// 習得: 同調・同★・同 T を持つ scale + arpeggio + etude のうち、
//       実在する全カテゴリで 1 つ以上演奏マスター
model UserTechniqueMastery {
  id             String    @id @default(cuid())
  userId         String
  techniqueTagId String
  isMastered     Boolean   @default(false)
  masteredAt     DateTime?
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  techniqueTag TechniqueTag @relation(fields: [techniqueTagId], references: [id], onDelete: Cascade)

  @@unique([userId, techniqueTagId])
  @@index([userId, isMastered])
}

// ─── (8) PracticeItemSubTaskTag: PracticeItem ⇔ sub_task の多対多 ───
// v1.3 §6-2 (8)
// 既存 PracticeItem.skillSubTaskTags JSON カラムの正規化版
// (両方残して移行は Phase 4 で整理)
model PracticeItemSubTaskTag {
  practiceItemId String
  subTaskType    String

  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id], onDelete: Cascade)

  @@id([practiceItemId, subTaskType])
  @@index([subTaskType])
}

// ─── (8b) ScoreTechniqueTag: Score ⇔ TechniqueTag の多対多 ───
// v1.3 Phase 3c 追加 (2026-05-16, Tetsuo Q4=B 確定)
// 完全習得判定 (§2-6) で「全演奏技法習得」を判定するために Score 自身に紐づく
// TechniqueTag 集合が必要。admin Score 登録 UI に技法選択 (Phase 4 で実装) →
// このテーブルに保存。PracticeItemTechnique と同じ M2M 構造。
model ScoreTechniqueTag {
  scoreId        String
  techniqueTagId String
  isPrimary      Boolean @default(false)

  score        Score        @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  techniqueTag TechniqueTag @relation(fields: [techniqueTagId], references: [id], onDelete: Cascade)

  @@id([scoreId, techniqueTagId])
  @@index([techniqueTagId])
}

// ─── (9) MissingPracticeItemFlag: 該当教材ゼロ件時の admin 通知フラグ ───
// v1.3 §2-4 / §6-2 (9) / I1 = A 確定
// 1 カテゴリでも該当教材 0 件なら sub_task 自体生成スキップ + このフラグ作成
model MissingPracticeItemFlag {
  id              String    @id @default(cuid())
  scoreId         String
  subTaskType     String
  missingCategory String // "scale" | "arpeggio" | "etude" のうち欠けている
  keyTonic        String
  keyMode         String
  star            Int
  techniqueTagId  String?
  detectedAt      DateTime  @default(now())
  resolvedAt      DateTime? // admin が該当教材登録した日時。null = 未解決

  score        Score         @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  techniqueTag TechniqueTag? @relation(fields: [techniqueTagId], references: [id], onDelete: SetNull)

  @@index([scoreId, resolvedAt])
  @@index([keyTonic, keyMode, star])
  @@index([resolvedAt])
}
