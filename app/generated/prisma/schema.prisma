generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  processing
  done
  error
  queued
  retrying
}

model User {
  id             String        @id @default(cuid())
  supabaseUserId String        @unique
  name           String
  role           Role          @default(student)
  plan           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  performances   Performance[]
  scores         Score[]

  // ▼ 練習メニュー追加分
  practiceItems        PracticeItem[]
  practicePerformances PracticePerformance[]
  weaknesses           UserWeakness[]

  @@index([role])
}

model Score {
  id               String        @id @default(cuid())
  createdById      String
  title            String
  composer         String?
  arranger         String?
  originalXmlPath  String
  generatedXmlPath String?
  analysisStatus   JobStatus     @default(processing)
  buildStatus      JobStatus     @default(processing)
  retryCount       Int           @default(0)
  errorMessage     String?
  lastAttemptedAt  DateTime?
  executionId      String?
  idempotencyKey   String?       @unique
  keyTonic         String?
  keyMode          String?
  timeNumerator    Int?
  timeDenominator  Int?
  defaultTempo     Int?
  isShared         Boolean       @default(false) // true=全ユーザー閲覧可のサンプル
  createdAt        DateTime      @default(now())
  deletedAt        DateTime? // 論理削除フラグ (NULL=有効、値あり=削除済み)
  performances     Performance[]
  createdBy        User          @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([isShared])
}

model Performance {
  id                   String            @id @default(cuid())
  performanceType      PerformanceType
  performanceStatus    PerformanceStatus @default(uploaded)
  userId               String
  scoreId              String
  audioPath            String
  audioFeaturesPath    String?
  comparisonResultPath String?
  pseudoXmlPath        String?
  performanceDuration  Float?
  performanceDate      DateTime?
  uploadedAt           DateTime          @default(now())
  createdAt            DateTime          @default(now())
  score                Score             @relation(fields: [scoreId], references: [id])
  user                 User              @relation(fields: [userId], references: [id])

  // ▼ 解析結果サマリー（段階3: ハイブリッド方式）
  pitchAccuracy   Float? // 0-100 ピッチ正確率（頻繁表示 → カラム）
  timingAccuracy  Float? // 0-100 タイミング正確率（頻繁表示 → カラム）
  overallScore    Float? // 0-100 総合スコア（pitch×0.6 + timing×0.4）
  evaluatedNotes  Int? // 評価対象ノート数
  analysisSummary Json? // 将来の拡張用（ビブラート・弓使い・音色等）

  // ▼ 非同期ジョブライフサイクル（Cloud Run Jobs）
  analysisStatus  JobStatus @default(done)
  retryCount      Int       @default(0)
  errorMessage    String?
  lastAttemptedAt DateTime?
  executionId     String?
  idempotencyKey  String?   @unique

  @@index([scoreId])
  @@index([userId, uploadedAt])
}

enum Role {
  student
  teacher
  admin
}

enum PerformanceType {
  user
  pro
}

enum PerformanceStatus {
  uploaded
  invalid
  deleted
}

// =============================================
// ▼ 練習メニュー機能
// =============================================

enum PracticeCategory {
  scale
  arpeggio
  etude
}

model PracticeItem {
  id               String           @id @default(cuid())
  category         PracticeCategory
  title            String
  composer         String?
  description      String?
  descriptionShort String?

  keyTonic   String
  keyMode    String
  tempoMin   Int?
  tempoMax   Int?
  positions  String[]
  instrument String   @default("violin")

  originalXmlPath  String
  generatedXmlPath String?
  analysisPath     String?
  analysisStatus   JobStatus @default(processing)
  buildStatus      JobStatus @default(processing)
  retryCount       Int       @default(0)
  errorMessage     String?
  lastAttemptedAt  DateTime?
  executionId      String?
  idempotencyKey   String?   @unique

  ownerUserId String? // null=運営サンプル（全員閲覧可）, 値あり=そのユーザーのみ
  owner       User?   @relation(fields: [ownerUserId], references: [id])

  source      String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  metadata    Json? // ▼ 追加
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  techniques           PracticeItemTechnique[]
  practicePerformances PracticePerformance[]

  @@index([category, keyTonic, keyMode])
  @@index([category, isPublished, sortOrder])
  @@index([ownerUserId])
}

model TechniqueTag {
  id              String   @id @default(cuid())
  category        String
  name            String
  nameEn          String?
  description     String?
  xmlTags         String[]
  isAnalyzable    String
  implementStatus String

  practiceItems PracticeItemTechnique[]
  weaknesses    UserWeakness[]

  @@unique([category, name])
  @@index([category])
}

model PracticeItemTechnique {
  practiceItemId String
  techniqueTagId String
  isPrimary      Boolean @default(false)

  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id])
  techniqueTag TechniqueTag @relation(fields: [techniqueTagId], references: [id])

  @@id([practiceItemId, techniqueTagId])
}

model PracticePerformance {
  id                   String   @id @default(cuid())
  userId               String
  practiceItemId       String
  audioPath            String
  comparisonResultPath String?
  performanceDuration  Float?
  uploadedAt           DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  practiceItem PracticeItem @relation(fields: [practiceItemId], references: [id])

  // ▼ 解析結果サマリー（段階3: ハイブリッド方式）
  pitchAccuracy   Float?
  timingAccuracy  Float?
  overallScore    Float?
  evaluatedNotes  Int?
  analysisSummary Json?

  // ▼ 非同期ジョブライフサイクル（Cloud Run Jobs）
  analysisStatus  JobStatus @default(done)
  retryCount      Int       @default(0)
  errorMessage    String?
  lastAttemptedAt DateTime?
  executionId     String?
  idempotencyKey  String?   @unique

  @@index([userId, practiceItemId, uploadedAt])
  @@index([practiceItemId])
}

model UserWeakness {
  id             String   @id @default(cuid())
  userId         String
  weaknessType   String
  weaknessKey    String
  techniqueTagId String?
  severity       Float
  sampleCount    Int
  lastUpdated    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  techniqueTag TechniqueTag? @relation(fields: [techniqueTagId], references: [id])

  @@unique([userId, weaknessType, weaknessKey])
  @@index([userId, severity])
}
